	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="30"/>
	<parameter name="usuario" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     usuarios.`idusuarios` AS usuarios_idusuarios,
     usuarios.`usuario` AS usuarios_usuario,
     usuarios.`clave` AS usuarios_clave,
     usuarios.`tipo` AS usuarios_tipo,
     usuarios.`estado` AS usuarios_estado,
     usuarios.`idpersonales` AS usuarios_idpersonales,
     personales.`per_nombre` AS personales_per_nombre,
     personales.`per_apellido` AS personales_per_apellido,
concat(personales.`per_nombre`," ",personales.`per_apellido`) as personal
FROM
     `personales` personales INNER JOIN `usuarios` usuarios ON personales.`idpersonales` = usuarios.`idpersonales`]]>
	</queryString>
	<field name="usuarios_idusuarios" class="java.lang.Integer"/>
	<field name="usuarios_usuario" class="java.lang.String"/>
	<field name="usuarios_clave" class="java.lang.String"/>
	<field name="usuarios_tipo" class="java.lang.String"/>
	<field name="usuarios_estado" class="java.lang.String"/>
	<field name="usuarios_idpersonales" class="java.lang.Integer"/>
	<field name="personales_per_nombre" class="java.lang.String"/>
	<field name="personales_per_apellido" class="java.lang.String"/>
	<field name="personal" class="java.lang.String"/>
