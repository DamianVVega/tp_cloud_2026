<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptcinco" pageWidth="555" pageHeight="802" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="411c4d5e-e1a7-4ed5-8eec-2e1db7f5a9b7">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="factura" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     detalleventas.`idventas` AS detalleventas_idventas,
     detalleventas.`det_cantidad` AS detalleventas_det_cantidad,
     detalleventas.`det_precio` AS detalleventas_det_precio,
     productos.`pro_iva` AS productos_pro_iva,
SUM(detalleventas.`det_cantidad` * detalleventas.`det_precio`) AS suma

FROM
     `productos` productos INNER JOIN `detalleventas` detalleventas ON productos.`idproductos` = detalleventas.`idproductos`
where detalleventas.`idventas`=$P{factura}  and productos.`pro_iva`='5']]>
	</queryString>
	<field name="detalleventas_idventas" class="java.lang.Integer"/>
	<field name="detalleventas_det_cantidad" class="java.lang.Integer"/>
	<field name="detalleventas_det_precio" class="java.lang.Integer"/>
	<field name="productos_pro_iva" class="java.lang.String"/>
	<field name="suma" class="java.math.BigDecimal"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="89" splitType="Stretch">
			<textField>
				<reportElement x="0" y="0" width="100" height="20" uuid="a90547b1-ba90-46f6-b480-104e7923f74c"/>
				<textElement verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[$F{suma} == null ? "" : String.valueOf($F{suma})]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
