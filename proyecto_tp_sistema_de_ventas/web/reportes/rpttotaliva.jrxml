<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rpttotaliva" pageWidth="555" pageHeight="802" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="91c3b781-121f-4b11-a4a7-d7320b4667d2">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="factura" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     detalleventas.`idventas` AS detalleventas_idventas,
     detalleventas.`det_cantidad` AS detalleventas_det_cantidad,
     detalleventas.`det_precio` AS detalleventas_det_precio,
     productos.`pro_iva` AS productos_pro_iva,

     SUM((detalleventas.`det_cantidad` * detalleventas.`det_precio`) / 11) AS suma_iva10,
     SUM((detalleventas.`det_cantidad` * detalleventas.`det_precio`) / 21) AS suma_iva5,
     SUM((detalleventas.`det_cantidad` * detalleventas.`det_precio`) / 11) +
     SUM((detalleventas.`det_cantidad` * detalleventas.`det_precio`) / 21) AS suma_total_iva

FROM
     productos
     INNER JOIN detalleventas ON productos.`idproductos` = detalleventas.`idproductos`

WHERE
     detalleventas.`idventas` = $P{factura}
]]>
	</queryString>
	<field name="detalleventas_idventas" class="java.lang.Integer"/>
	<field name="detalleventas_det_cantidad" class="java.lang.Integer"/>
	<field name="detalleventas_det_precio" class="java.lang.Integer"/>
	<field name="productos_pro_iva" class="java.lang.String"/>
	<field name="suma_iva10" class="java.math.BigDecimal"/>
	<field name="suma_iva5" class="java.math.BigDecimal"/>
	<field name="suma_total_iva" class="java.math.BigDecimal"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="125" splitType="Stretch">
			<textField pattern="#,##0">
				<reportElement x="0" y="0" width="100" height="20" uuid="26af660c-349e-4e58-928b-674d2d2e6883"/>
				<textElement verticalAlignment="Middle">
					<font size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{suma_total_iva}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
